# Copy to .env; docker compose reads it automatically.
BLOG_PROVIDER=ollama
BLOG_MODEL=llama3.1
BLOG_MAX_REVISIONS=2

# In-cluster Ollama (default). To use a model on the HOST instead:
#   BLOG_BASE_URL=http://host.docker.internal:11434/v1   # host Ollama
#   BLOG_BASE_URL=http://host.docker.internal:1234/v1    # LM Studio
#   BLOG_PROVIDER=lmstudio
BLOG_BASE_URL=http://ollama:11434/v1

# Level 1 Search Provider API Keys (optional; falls back to 'mock' if not set)
# SEARCH_PROVIDER=tavily  # tavily, brave, serper, google, mock
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# SERPER_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=
